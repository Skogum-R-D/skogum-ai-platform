MISTRAL_API_KEY=your_key_here
VALKEY_URL=valkey://localhost:6379
GITHUB_TOKEN=ghp_...
GH_ORG=your-org-name

# Optional model overrides
PM_MODEL=mistral-large-latest
RESEARCHER_MODEL=mistral-medium-latest
ENGINEER_MODEL=devstral-latest
QA_MODEL=devstral-latest
INFRA_MODEL=mistral-medium-latest

# MCP servers — JSON array, applied to ALL agents (or set per-service in docker-compose.yml)
# Each entry: {"prefix": "...", "command": "...", "args": [...], "env": {...}}
# MCP_SERVERS=[{"prefix":"fetch","command":"uvx","args":["mcp-server-fetch"]},{"prefix":"gh","command":"npx","args":["-y","@modelcontextprotocol/server-github"],"env":{"GITHUB_TOKEN":"..."}}]
MCP_SERVERS=
